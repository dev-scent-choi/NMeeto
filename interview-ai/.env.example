# ── 데이터베이스 / 캐시 / 스토리지 ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nmeeto:nmeeto@localhost:5432/nmeeto_dev
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=nmeeto
S3_ACCESS_KEY=nmeeto
S3_SECRET_KEY=nmeeto_secret

# ── 인증 ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=2592000

# ── LLM ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MODEL_PLANNER=claude-opus-4-8
MODEL_INTERVIEWER=claude-sonnet-5
MODEL_JUDGE=claude-haiku-4-5-20251001

# ── STT / TTS (Phase 2 이후) ──────────────────────────────────────────────
STT_PROVIDER=whisper
STT_API_KEY=
TTS_PROVIDER=openai
TTS_API_KEY=
TTS_VOICE_ID=

# ── 웹 검색 (기출 질문 소싱) ──────────────────────────────────────────────
SEARCH_API_KEY=

# ── 운영 정책 (하드코딩 금지) ─────────────────────────────────────────────
MAX_SESSION_MINUTES=30
MAX_FOLLOWUPS_PER_QUESTION=2
DAILY_SESSION_LIMIT_FREE=1
MONTHLY_COST_CAP_USD_PER_USER=5
LLM_TIMEOUT_MS=8000
AUDIO_RETENTION_DAYS=90

# ── 개발 ──────────────────────────────────────────────────────────────────
MOCK_LLM=false
LOG_LEVEL=info
ENVIRONMENT=development

# ── 퍼블릭 URL (백엔드가 프론트엔드에 알려주는 WS 주소) ─────────────────
PUBLIC_WS_URL=ws://localhost:8000

# ── 프론트엔드 환경변수 ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
